{
  "name": "@as-pect/cli",
  "version": "9.0.0",
  "description": "Write AssemblyScript tests at blazing fast speeds",
  "exports": {
    ".": "./lib/index.js"
  },
  "types": "lib/index.d.ts",
  "type": "module",
  "scripts": {
    "clean": "node ../../scripts/clean.mjs lib",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "tsc:cli": "node ../../scripts/run-npm-scripts.mjs clean tsc",
    "tsc": "tsc"
  },
  "bin": {
    "asp": "./bin/asp.js",
    "aspect": "./bin/asp.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jtenner/as-pect/tree/master/packages/cli"
  },
  "author": "Joshua Tenner <tenner.joshua@gmail.com>",
  "license": "MIT",
  "keywords": [
    "wasm",
    "assemblyscript",
    "testing",
    "cli"
  ],
  "bugs": {
    "url": "https://github.com/jtenner/aspect/issues"
  },
  "homepage": "https://github.com/jtenner/as-pect#readme",
  "dependencies": {
    "@as-covers/core": "0.4.2",
    "@as-covers/transform": "0.4.2",
    "@as-pect/assembly": "^9.0.0",
    "@as-pect/core": "^9.0.0",
    "@as-pect/transform": "^9.0.0",
    "@assemblyscript/loader": "^0.28.19",
    "glob": "^13.0.6",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "assemblyscript": "^0.28.19"
  },
  "devDependencies": {
    "assemblyscript": "^0.28.19"
  },
  "optionalDependencies": {
    "@as-pect/csv-reporter": "^9.0.0",
    "@as-pect/ctrf-reporter": "^9.0.0",
    "@as-pect/json-reporter": "^9.0.0",
    "@as-pect/junit-reporter": "^9.0.0"
  },
  "files": [
    "init/",
    "lib/",
    "bin/"
  ],
  "publishConfig": {
    "access": "public"
  }
}
